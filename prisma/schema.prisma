// Pawly Prisma schema
// Provider: PostgreSQL (Railway)
// Run: pnpm db:migrate (dev) or pnpm db:migrate:deploy (prod)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// Auth.js / NextAuth tables (PrismaAdapter)
// =============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Future-proof for premium tiers without building paywall UI yet.
  tier          String   @default("free")

  accounts Account[]
  sessions Session[]
  dogs     Dog[]
  pushSubscriptions PushSubscription[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================
// Pawly domain
// =============================================================

enum Sex {
  M
  F
}

enum WeightUnit {
  KG
  LB
}

enum WalkStyle {
  ON_LEAD
  OFF_LEAD
  MIXED
}

enum TaskType {
  FEEDING
  EXERCISE
  HEALTH
  WELLNESS
  TRAINING
  MEDICATION
}

enum TaskStatus {
  OPEN
  DONE
  SNOOZED
  SKIPPED
}

enum HealthRecordType {
  VACCINE
  PARASITE
  MEDICATION
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ChatSeverity {
  NORMAL
  URGENT
}

model Dog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  photoUrl  String?
  breed     String?
  breedSecondary String?
  dob       DateTime?
  sex       Sex?
  neutered  Boolean?
  weight    Float?
  weightUnit WeightUnit @default(KG)

  // Health
  conditions String[]   @default([])
  allergies  String[]   @default([])

  // Vet
  vetName    String?
  vetClinic  String?
  vetPhone   String?

  // Diet
  food          String?
  feedingTimes  String[] @default(["08:00", "18:00"])

  // Lifestyle
  exerciseMins  Int       @default(60)
  walkStyle     WalkStyle @default(MIXED)
  livesWithDogs Int       @default(0)
  livesWithKids Boolean   @default(false)

  // Personality (1-5 sliders)
  energy     Int @default(3)
  confidence Int @default(3)
  social     Int @default(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks         Task[]
  healthRecords HealthRecord[]
  chatMessages  ChatMessage[]
  weightLogs    WeightLog[]
  diaryEntries  DiaryEntry[]

  @@index([userId])
}

model Task {
  id        String     @id @default(cuid())
  dogId     String
  dog       Dog        @relation(fields: [dogId], references: [id], onDelete: Cascade)

  type      TaskType
  title     String
  subtitle  String?
  iconKey   String?
  scheduledFor DateTime
  timeOfDay String?    // "HH:MM" or null

  status      TaskStatus @default(OPEN)
  urgent      Boolean    @default(false)

  completedAt   DateTime?
  snoozedUntil  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dogId, status])
  @@index([scheduledFor])
}

model HealthRecord {
  id        String   @id @default(cuid())
  dogId     String
  dog       Dog      @relation(fields: [dogId], references: [id], onDelete: Cascade)

  type        HealthRecordType
  name        String
  product     String?
  doseMg      Float?
  frequency   String?
  intervalDays Int?

  lastGiven DateTime?
  nextDue   DateTime?

  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dogId, type])
  @@index([nextDue])
}

model ChatMessage {
  id        String        @id @default(cuid())
  dogId     String
  dog       Dog           @relation(fields: [dogId], references: [id], onDelete: Cascade)

  role      ChatRole
  content   String        @db.Text
  severity  ChatSeverity? @default(NORMAL)

  createdAt DateTime @default(now())

  @@index([dogId, createdAt])
}

model WeightLog {
  id         String     @id @default(cuid())
  dogId      String
  dog        Dog        @relation(fields: [dogId], references: [id], onDelete: Cascade)

  weight     Float
  weightUnit WeightUnit @default(KG)
  notedAt    DateTime   @default(now())
  notes      String?

  createdAt  DateTime   @default(now())

  @@index([dogId, notedAt])
}

model DiaryEntry {
  id        String   @id @default(cuid())
  dogId     String
  dog       Dog      @relation(fields: [dogId], references: [id], onDelete: Cascade)

  photoUrl  String   @db.Text
  caption   String?

  createdAt DateTime @default(now())

  @@index([dogId, createdAt])
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint   String   @unique @db.Text
  p256dh     String   @db.Text
  authSecret String   @db.Text

  createdAt  DateTime @default(now())

  @@index([userId])
}

// =============================================================
// Feature Flags
// =============================================================

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique   // e.g. "ai-chat", "multi-dog"
  description String
  enabled     Boolean  @default(false)  // global default
  rolloutPct  Int      @default(0)      // 0–100, % of users who get it when enabled
  // Optional string value — used for model ID flags (e.g. "claude-sonnet-4-6")
  // When set, getFlags() returns this string instead of the boolean enabled value
  stringValue String?  @default("")

  // Geo targeting — ISO 3166-1 alpha-2 country codes.
  // Empty array = available in ALL countries (no geo gate).
  // Non-empty = only available in listed countries.
  // Regions: UK_IE (GB,IE), EU (DE,FR,NL…), US, APAC (AU,NZ,SG…)
  countries   String[] @default([])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  overrides FlagOverride[]
}

// Per-user overrides — force on/off for specific users
model FlagOverride {
  id        String   @id @default(cuid())
  flagId    String
  flag      FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)
  userId    String
  enabled   Boolean  // overrides global + rollout
  createdAt DateTime @default(now())

  @@unique([flagId, userId])
  @@index([userId])
}
