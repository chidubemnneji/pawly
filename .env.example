# ============================================================
# Pawly — environment variables
# Copy this to .env.local for local dev. In production, set
# these in Vercel (app vars) and Railway (DATABASE_URL).
# ============================================================

# --- Database (Railway Postgres) ---
# In Railway: Project → Postgres → "Connect" → "Postgres Connection URL"
# Use the DIRECT connection URL for migrations (not the connection pooler).
DATABASE_URL="postgresql://postgres:password@host:5432/railway"

# --- Auth.js (NextAuth v5) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="REPLACE_ME_WITH_A_LONG_RANDOM_STRING"

# Public URL of your deployed app (used by Auth.js for callbacks).
# In Vercel, Auth.js auto-detects from VERCEL_URL — leave blank in prod.
NEXTAUTH_URL="http://localhost:3000"

# --- Auth providers (all optional — app works without them in DEMO mode) ---
# Google OAuth: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email (magic links via Resend): https://resend.com/api-keys
AUTH_RESEND_KEY=""
AUTH_EMAIL_FROM="Pawly <hello@yourdomain.com>"

# --- Anthropic (Claude AI) ---
# Get a key from https://console.anthropic.com
# If not set, the chat falls back to a profile-aware mock so the app still runs.
ANTHROPIC_API_KEY=""

# --- Demo mode ---
# When 'true', the app skips auth and uses an in-memory demo user.
# Set to 'false' (or unset) in production.
PAWLY_DEMO_MODE="true"

# --- Web push (optional) ---
# Generate with: npx web-push generate-vapid-keys
# The PUBLIC key is exposed to the browser (NEXT_PUBLIC_*). Private stays on the server.
# If unset, the "Enable reminders" card hides itself — the rest of the app still works.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:hello@yourdomain.com"
